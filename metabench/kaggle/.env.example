# Kaggle API (required for Option B)
KAGGLE_API_TOKEN=KGAT_xxxxx
KAGGLE_USERNAME=your_kaggle_username

# Option A only — live Kaggle notebook session
# Get these from the notebook Jupyter proxy URL while the notebook is open.
KAGGLE_JUPYTER_URL=https://kkb-production.jupyter-proxy.kaggle.net
KAGGLE_JUPYTER_TOKEN=eyJhbGc...

# Option A only — benchmark model proxy
# These only work from Kaggle's network.
MODEL_PROXY_URL=https://mp-staging.kaggle.net/models/openapi
MODEL_PROXY_API_KEY=kaggle-benchmarks:...
LLM_DEFAULT=google/gemini-2.5-flash
LLM_DEFAULT_EVAL=google/gemini-2.5-flash
